{
  "name": "wugi-functions",
  "description": "Wugi Firebase Cloud Functions",
  "scripts": {
    "build": "node node_modules/typescript/bin/tsc",
    "build:watch": "tsc --watch",
    "serve": "npm run build && firebase emulators:start --only functions",
    "shell": "npm run build && firebase functions:shell",
    "start": "npm run shell",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log",
    "test:grammar": "tsc && node scripts/test-inbound-grammar.js"
  },
  "engines": {
    "node": "20"
  },
  "main": "lib/index.js",
  "dependencies": {
    "exif-reader": "^2.0.3",
    "firebase-admin": "^12.0.0",
    "firebase-functions": "^5.0.0",
    "passkit-generator": "^3.5.7",
    "resend": "^6.10.0",
    "sharp": "^0.33.5",
    "stripe": "^14.0.0",
    "twilio": "^5.13.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.9.3"
  },
  "private": true
}