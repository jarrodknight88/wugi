rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Allow public reads (for venue discovery, events, etc.)
    match /{document=**} {
      allow read: if true;
    }

    // Allow writes only for authenticated users
    match /{document=**} {
      allow write: if request.auth != null;
    }

  }
}