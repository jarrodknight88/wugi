rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ─────────────────────────────────────────────
    function userDocExists() {
      return isAuth() && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }
    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    function isAuth()       { return request.auth != null; }
    // Always guard userDoc() calls with userDocExists() to prevent errors on
    // brand-new accounts where the users/{uid} doc hasn't been created yet.
    function role()         { return (isAuth() && userDocExists()) ? userDoc().role : null; }
    function venueIds()     { return (isAuth() && userDocExists()) ? userDoc().get('venueIds', []) : []; }
    function eventIds()     { return (isAuth() && userDocExists()) ? userDoc().get('eventIds', []) : []; }
    function tableAccess()  { return (isAuth() && userDocExists()) && userDoc().get('tableAccess', false) == true; }

    function isSuperAdmin()  { return role() == 'super_admin'; }
    function isModerator()   { return role() == 'moderator'; }
    function isSupport()     { return role() == 'support'; }
    function isVenueAdmin()  { return role() == 'venue_admin'; }
    function isVenueStaff()  { return role() == 'venue_staff'; }
    function isEventAdmin()  { return role() == 'event_admin'; }
    function isEventStaff()  { return role() == 'event_staff'; }

    function isStaff()  { return isSuperAdmin() || isModerator() || isSupport(); }
    function canWrite() { return isStaff() || isVenueAdmin() || isEventAdmin(); }

    function canAccessVenue(venueId) {
      return isStaff()
        || (isVenueAdmin()  && venueId in venueIds())
        || (isVenueStaff()  && venueId in venueIds());
    }

    function canWriteVenue(venueId) {
      return isStaff() || (isVenueAdmin() && venueId in venueIds());
    }

    function canAccessEvent(eventId, venueId) {
      return isStaff()
        || (isVenueAdmin()  && venueId in venueIds())
        || (isVenueStaff()  && venueId in venueIds())
        || (isEventAdmin()  && eventId in eventIds())
        || (isEventStaff()  && eventId in eventIds());
    }

    function canWriteEvent(eventId, venueId) {
      return isStaff()
        || (isVenueAdmin() && venueId in venueIds())
        || (isEventAdmin() && eventId in eventIds());
    }

    // ── Users ────────────────────────────────────────────────────────
    // Users must be readable by any authenticated user — the userDoc()
    // helper calls get() on this collection to resolve roles, so we cannot
    // gate reads behind role checks (that would cause infinite recursion).
    match /users/{userId} {
      allow read:   if isAuth();
      allow create: if isAuth() && request.auth.uid == userId;
      // Own-user check MUST come first — isSuperAdmin() calls userDoc() which
      // will fail if the doc doesn't exist yet (brand new account race condition).
      allow update: if isAuth() && (
        request.auth.uid == userId
        || isSuperAdmin()
        || isVenueAdmin()
      );
      allow delete: if isSuperAdmin();

      match /activity/{activityId} {
        allow read:   if isAuth() && request.auth.uid == userId;
        allow create: if isAuth() && request.auth.uid == userId;
        allow update, delete: if false;
      }
    }

    // ── Venues ───────────────────────────────────────────────────────
    match /venues/{venueId} {
      allow read:   if true;  // public
      allow create: if isStaff() || isVenueAdmin();
      allow update: if canWriteVenue(venueId);
      allow delete: if isStaff();

      match /tableColors/{colorId} {
        allow read:  if true;
        allow write: if canWriteVenue(venueId);
      }

      match /tables/{tableId} {
        allow read:  if canAccessVenue(venueId);
        allow write: if canWriteVenue(venueId);
      }

      match /tableGroups/{groupId} {
        allow read:  if canAccessVenue(venueId);
        allow write: if canWriteVenue(venueId);
      }
    }

    // ── Events ───────────────────────────────────────────────────────
    match /events/{eventId} {
      allow read:   if true;  // public
      allow create: if canWrite();
      allow update: if canWriteEvent(eventId, resource.data.venueId);
      allow delete: if isStaff();

      match /ticketTypes/{ttId} {
        allow read:   if true;
        allow write:  if canWriteEvent(eventId, get(/databases/$(database)/documents/events/$(eventId)).data.venueId);
      }

      // Per-event tickets subcollection — used by check-in page
      match /tickets/{ticketId} {
        allow read: if canAccessEvent(eventId, get(/databases/$(database)/documents/events/$(eventId)).data.venueId);
        // Allow dashboard users to check in and assign colors
        allow update: if canAccessEvent(eventId, get(/databases/$(database)/documents/events/$(eventId)).data.venueId)
          && request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['checkedIn','checkedInAt','checkedInBy','color','passUpdatedAt','updatedAt','tableAssignment','depositPaid','balanceDue','idVerification']);
        allow create: if canAccessEvent(eventId, get(/databases/$(database)/documents/events/$(eventId)).data.venueId);
        allow delete: if false;
      }

      match /tableReservations/{resId} {
        allow read:  if canAccessEvent(eventId, get(/databases/$(database)/documents/events/$(eventId)).data.venueId);
        allow write: if false;  // Cloud Functions only
      }
    }

    // ── Event Series ─────────────────────────────────────────────────
    match /eventSeries/{seriesId} {
      allow read:   if true;
      allow create: if canWrite();
      allow update: if isStaff()
        || (isVenueAdmin() && resource.data.venueId in venueIds())
        || (isEventAdmin() && resource.data.promoterId == request.auth.uid);
      allow delete: if isStaff();
    }

    // ── Orders ───────────────────────────────────────────────────────
    match /orders/{orderId} {
      allow read: if isAuth() && (
        request.auth.uid == resource.data.userId
        || isStaff()
        || (isVenueAdmin() && resource.data.venueId in venueIds())
        || (isEventAdmin() && resource.data.eventId in eventIds())
      );
      allow write: if false;  // Cloud Functions only
    }

    // ── Tickets ──────────────────────────────────────────────────────
    match /tickets/{ticketId} {
      allow read: if true;
      allow update: if
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['checkedIn','checkedInAt','checkedInBy'])
        && request.resource.data.checkedIn == true;
      allow create, delete: if false;
    }

    // ── Event PINs ───────────────────────────────────────────────────
    match /eventPins/{pinId} {
      allow read:  if true;   // check-in devices read without auth
      allow write: if false;  // Cloud Functions only
    }

    // ── Tickets collection group — for Door app (PIN-based, no Firebase Auth) ─
    match /{path=**}/tickets/{ticketId} {
      allow read: if true;
      // Allow Door app to check in guests and change ticket colors
      allow update: if request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(['checkedIn','checkedInAt','checkedInBy','color','passUpdatedAt',
                  'updatedAt','tableAssignment','depositPaid','balanceDue','idVerification',
                  'idVerificationBypassed']);
    }

    // ── Event Galleries ──────────────────────────────────────────────
    match /eventGalleries/{galleryId} {
      allow read: if true;
      allow create: if isAuth();
      allow update: if isAuth() && (
        request.auth.uid == resource.data.photographerId || isStaff()
      );
      allow delete: if isStaff();

      // Photo reads: published photos stay public, but Lens Phase 1 pending/
      // rejected docs are only visible to the assigned photographer or staff.
      // List queries must carry a provable filter: consumer surfaces already
      // query where('approved','==',true) (useEventGallery, web gallery page);
      // the Lens pending pool queries where('photographerId','==',uid).
      match /photos/{photoId} {
        allow read: if resource.data.approved == true
          || (isAuth() && request.auth.uid == resource.data.photographerId)
          || isStaff();
        allow create: if isAuth();
        allow update: if isAuth() && (
          request.auth.uid == resource.data.photographerId || isStaff()
        );
        allow delete: if isStaff();
      }
    }

    // ── Lens Devices ─────────────────────────────────────────────────
    // devices/{deviceId} — hardware capture device registry (Lens Phase 1).
    // Assignment (venueId/eventId/galleryId/photographerId), mode and active
    // toggle are admin-only. The device itself (authenticated as its dedicated
    // auth user, authUid) may only write its own heartbeat fields.
    match /devices/{deviceId} {
      allow read: if isAuth();
      allow create, delete: if isStaff();
      allow update: if isStaff()
        || (isAuth() && request.auth.uid == resource.data.authUid
            && request.resource.data.diff(resource.data).affectedKeys()
                .hasOnly(['heartbeatAt', 'batteryPct', 'updatedAt']));
    }

    // ── Lens Quarantine Log ──────────────────────────────────────────
    // Written by the ingest Cloud Function when an upload fails device/
    // gallery validation. Read-only for staff.
    match /lensQuarantine/{entryId} {
      allow read:  if isStaff();
      allow write: if false;  // Cloud Functions only
    }

    // ── Audit Logs ───────────────────────────────────────────────────
    match /auditLogs/{logId} {
      allow read:  if isStaff();
      allow write: if false;  // Cloud Functions only
    }

    // ── Config ───────────────────────────────────────────────────────
    match /config/{configId} {
      allow read:  if true;
      allow write: if isSuperAdmin();
    }

    // ── Usernames ────────────────────────────────────────────────────
    // usernames/{username} → { uid, claimedAt }
    // Any auth'd user can read (for availability checks).
    // Only the owning user can claim/update their username doc.
    match /usernames/{username} {
      allow read: if isAuth();
      allow create: if isAuth() && request.resource.data.uid == request.auth.uid;
      allow update: if isAuth() && resource.data.uid == request.auth.uid;
      allow delete: if isSuperAdmin();
    }

    // ── Phone Index ──────────────────────────────────────────────────
    // phoneIndex/{e164Phone} → { uid, claimedAt }
    // Written by Cloud Function or authenticated owner only.
    match /phoneIndex/{phone} {
      allow read:   if isAuth() && (isSuperAdmin() || resource.data.uid == request.auth.uid);
      allow create: if isAuth() && request.resource.data.uid == request.auth.uid;
      allow update: if isAuth() && resource.data.uid == request.auth.uid;
      allow delete: if isSuperAdmin();
    }

    // ── Passes / Wallets / Transfers ─────────────────────────────────
    // passes: allow list queries by userId (needed for MyPassesScreen)
    // and individual doc reads for pass viewer
    match /passes/{passId} {
      allow read: if isAuth() && (
        request.auth.uid == resource.data.userId  // single doc read
        || isStaff()
      );
      // Allow list queries — Firestore evaluates the where clause, rule just needs isAuth()
      allow list: if isAuth();
      // Cloud Functions own all writes EXCEPT:
      // Dashboard staff can update check-in status and pass color
      allow update: if isStaff() && request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(['scanStatus','scannedAt','scannedBy','passColor','updatedAt',
                  'depositPaid','balanceDue','tableAssignment']);
      allow create, delete: if false;  // Cloud Functions only
    }
    match /walletPasses/{passId}   { allow read: if isAuth() && request.auth.uid == resource.data.userId; allow write: if false; }
    match /walletDevices/{deviceId}{ allow read, write: if false; }
    match /transfers/{transferId}  { allow read: if isAuth() && (request.auth.uid == resource.data.fromUid || isStaff()); allow write: if false; }
    match /payouts/{id}            { allow read: if isStaff(); allow write: if false; }
    match /chargebacks/{id}        { allow read: if isStaff(); allow write: if false; }

    // ── Favorites ────────────────────────────────────────────────────
    // Top-level `favorites` collection. Doc id is deterministic
    // `${userId}_${itemType}_${itemId}`; each doc carries its owner's uid.
    // A user may only read/write their OWN favorites. The consumer app reads
    // its own set on login (list by userId) and writes via add/removeFavorite.
    match /favorites/{favId} {
      allow read:   if isAuth() && resource.data.userId == request.auth.uid;
      allow list:   if isAuth();  // where(userId == uid) query; rule needs auth
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuth() && resource.data.userId == request.auth.uid
                    && request.resource.data.userId == request.auth.uid;
      allow delete: if isAuth() && resource.data.userId == request.auth.uid;
    }

    // ── Unlocks ──────────────────────────────────────────────────────
    // Top-level `unlocks` collection — the photo-entitlement ledger
    // (Asana 1216729526587350). Doc id is deterministic `${userId}_${photoId}`
    // (photoId is the synthetic `${galleryId}-${index}` id, matching
    // `favorites`). Unrefundable, spent-credit semantics: a user may only
    // ever READ their own unlocks; ALL writes (free-credit spend + future
    // purchased-unlock creation) happen exclusively via Cloud Functions
    // (spendFreeUnlock), which run with the Admin SDK and bypass these rules.
    // Photographer earnings aggregation reads this collection server-side
    // (getPhotographerEarnings), also via the Admin SDK — photographers do
    // NOT get direct client read access to other users' unlock docs here.
    match /unlocks/{unlockId} {
      allow read: if isAuth() && resource.data.userId == request.auth.uid;
      allow list: if isAuth();  // where(userId == uid) query; rule needs auth
      allow write: if false;    // Cloud Functions only
    }

    // ── Reports ──────────────────────────────────────────────────────
    // Top-level `reports` collection. Users flag photos; the doc is created
    // with status 'open' and the reporter's uid. Reporters can read their own
    // reports; staff can read all. Resolution happens via the Dashboard /
    // admin SDK (no client update/delete).
    match /reports/{reportId} {
      allow create: if isAuth()
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.status == 'open';
      allow read:   if isAuth() && (resource.data.userId == request.auth.uid || isStaff());
      allow update, delete: if false;
    }

    // ── Catch-all ────────────────────────────────────────────────────
    match /{document=**} {
      allow read:  if isAuth();
      allow write: if false;
    }
  }
}
