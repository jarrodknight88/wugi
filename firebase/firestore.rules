rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    function isAuth()                  { return request.auth != null; }
    function isSuperAdmin()            { return isAuth() && userDoc().role == 'super_admin'; }
    function isModerator()             { return isAuth() && userDoc().role == 'moderator'; }
    function isSuperAdminOrModerator() { return isSuperAdmin() || isModerator(); }

    // ── Users — auth required, own doc only ──────────────────────────
    match /users/{userId} {
      allow read:          if isAuth() && request.auth.uid == userId;
      allow create, update: if isSuperAdmin();
    }

    // ── Venues — PUBLIC read (unclaimed venues visible to all) ────────
    match /venues/{venueId} {
      allow read:                  if true;
      allow create, update, delete: if isSuperAdminOrModerator();
    }

    // ── Events — PUBLIC read ──────────────────────────────────────────
    match /events/{eventId} {
      allow read:                  if true;
      allow create, update, delete: if isSuperAdminOrModerator();

      // Ticket types subcollection — PUBLIC read
      match /ticketTypes/{ticketTypeId} {
        allow read:                  if true;
        allow create, update, delete: if isSuperAdminOrModerator();
      }
    }

    // ── Orders — auth required, owner or admin ────────────────────────
    match /orders/{orderId} {
      allow read:   if isAuth() && (request.auth.uid == resource.data.userId || isSuperAdminOrModerator());
      allow write:  if false; // Only Cloud Functions write orders
    }

    // ── Passes — auth required, holder or venue staff ─────────────────
    match /passes/{passId} {
      allow read:   if isAuth() && (request.auth.uid == resource.data.userId || isSuperAdminOrModerator());
      allow update: if isAuth() && isSuperAdminOrModerator(); // Scan via Cloud Function
      allow write:  if false;
    }

    // ── Config — PUBLIC read (ticketing fees, feature flags) ──────────
    match /config/{configId} {
      allow read:  if true;
      allow write: if isSuperAdmin();
    }

    // ── Audit logs — admin only ───────────────────────────────────────
    match /auditLogs/{logId} {
      allow read:  if isSuperAdminOrModerator();
      allow write: if false;
    }

    // ── Payouts / Chargebacks — admin only ────────────────────────────
    match /payouts/{payoutId} {
      allow read:  if isAuth() && isSuperAdminOrModerator();
      allow write: if false;
    }
    match /chargebacks/{chargebackId} {
      allow read:  if isAuth() && isSuperAdminOrModerator();
      allow write: if false;
    }

    // ── Catch-all — auth required for anything else ───────────────────
    match /{document=**} {
      allow read:  if isAuth();
      allow write: if false;
    }
  }
}
