{
  "expo": {
    "name": "Wugi",
    "slug": "wugi",
    "version": "5.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "cover",
      "backgroundColor": "#0a0a0a"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.wugimedia.wugitest",
      "buildNumber": "1",
      "googleServicesFile": "./GoogleService-Info.plist",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Wugi uses your location to show nearby venues and events.",
        "NSCameraUsageDescription": "Wugi uses your camera to upload photos.",
        "NSPhotoLibraryUsageDescription": "Wugi needs access to your photos to upload images.",
        "NSMicrophoneUsageDescription": "Wugi uses your microphone for video recording.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "plugins": [
      "expo-av",
      "@react-native-firebase/app",
      "./plugins/fix-folly-convert",
      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "static",
            "buildReactNativeFromSource": true
          }
        }
      ],
      ["@stripe/stripe-react-native", {
        "merchantIdentifier": "merchant.com.wugimedia.wugitest",
        "enableGooglePay": false
      }]
    ],
    "extra": {
      "eas": {
        "projectId": "02118aa1-ca85-4fed-87a2-be67c8e6255b"
      }
    },
    "android": {
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "CAMERA",
        "RECORD_AUDIO",
        "READ_MEDIA_IMAGES",
        "READ_MEDIA_VIDEO",
        "ACCESS_FINE_LOCATION"
      ],
      "package": "com.wugimedia.wugitest"
    }
  }
}
